{
  "name": "remesas",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "start:api": "cd backend && npm run dev",
    "dev": "concurrently --kill-others \"npm run start:api\" \"npm run start\""
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "overrides": {
    "shell-quote": "1.10.0"
  },
  "dependencies": {
    "@angular/common": "21.2.18",
    "@angular/compiler": "21.2.18",
    "@angular/core": "21.2.18",
    "@angular/forms": "21.2.18",
    "@angular/platform-browser": "21.2.18",
    "@angular/router": "21.2.18",
    "qrcode": "1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.19",
    "@angular/cli": "21.2.19",
    "@angular/compiler-cli": "21.2.18",
    "@types/qrcode": "1.5.6",
    "concurrently": "^10.0.3",
    "typescript": "~5.9.2"
  }
}
